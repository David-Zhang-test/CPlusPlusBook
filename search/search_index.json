{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"]},"docs":[{"location":"","title":"Welcome to MkDocs","text":"<p>For full documentation visit mkdocs.org.</p>"},{"location":"#commands","title":"Commands","text":"<ul> <li><code>mkdocs new [dir-name]</code> - Create a new project.</li> <li><code>mkdocs serve</code> - Start the live-reloading docs server.</li> <li><code>mkdocs build</code> - Build the documentation site.</li> <li><code>mkdocs -h</code> - Print help message and exit.</li> </ul>"},{"location":"#project-layout","title":"Project layout","text":"<pre><code>mkdocs.yml    # The configuration file.\ndocs/\n    index.md  # The documentation homepage.\n    ...       # Other markdown pages, images and other files.\n</code></pre>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/","title":"\u8ba1\u7b97\u673a\u8bed\u8a00\u7eea\u8bba","text":""},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#_1","title":"\u4e00\u3001\u8ba1\u7b97\u673a\u8bed\u8a00\u7684\u53d1\u5c55\u548c\u6f14\u53d8","text":"<p>\u7a0b\u5e8f\u662f\u6307\u4ee4\u7684\u96c6\u5408\uff0c\u6307\u4ee4\u662f\u8ba1\u7b97\u673a\u53ef\u6267\u884c\u7684\u547d\u4ee4</p> <ol> <li>\u673a\u5668\u8bed\u8a00\uff1a\u8ba1\u7b97\u673a\u53ef\u76f4\u63a5\u8bfb\u53d6\u673a\u5668\u8bed\u8a00\uff0c\u4f46\u5176\u4e0e\u4eba\u7c7b\u8bed\u8a00\u533a\u522b\u5927\uff0c\u96be\u5ea6\u9ad8</li> <li>\u6c47\u7f16\u8bed\u8a00\uff1a\u5c06\u4e00\u4e9b\u673a\u5668\u6307\u4ee4\u6620\u5c04\u4e3a\u53ef\u8bfb\u61c2\u7684\u52a9\u8bb0\u7b26\uff0c\u8fdb\u6b65\u5728\u4e8e\u521b\u9020\u4e86\u6c47\u7f16\u7a0b\u5e8f\uff0c\u4f46\u4ecd\u4e0e\u4eba\u7c7b\u601d\u7ef4\u76f8\u5dee\u592a\u8fdc</li> <li>\u9ad8\u7ea7\u8bed\u8a00\uff1a\u5c4f\u853d\u4e86\u673a\u5668\u7684\u7ec6\u8282\uff0c\u63d0\u9ad8\u4e86\u8bed\u8a00\u7684\u62bd\u8c61\u5c42\u6b21\uff0c\u7f3a\u70b9\u5728\u4e8e\u7a0b\u5e8f\u4e2d\u6570\u636e\u548c\u64cd\u4f5c\u4e0d\u80fd\u5206\u79bb</li> <li>\u9762\u5411\u5bf9\u8c61\u8bed\u8a00\uff1a\u901a\u8fc7\u62bd\u8c61\u51fa\u5ba2\u89c2\u4e8b\u7269\u7684\u5171\u6709\u884c\u4e3a\u548c\u5c5e\u6027\u5f62\u6210\u7c7b\uff0c\u5927\u5927\u63d0\u9ad8\u4e86\u4ee3\u7801\u6548\u7387 </li> </ol>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#_2","title":"\u4e8c\u3001\u9762\u5411\u5bf9\u8c61","text":""},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#21","title":"2.1 \u9762\u5411\u8fc7\u7a0b\u4e0e\u9762\u5411\u5bf9\u8c61","text":"<p>\u9762\u5411\u8fc7\u7a0b\u5c06\u95ee\u9898\u62c6\u89e3\u4e3a\u591a\u4e2a\u6b65\u9aa4\uff0c\u91c7\u7528\u7ed3\u6784\u5316\u7684\u8bbe\u8ba1\u601d\u8def\uff0c\u6bcf\u4e2a\u529f\u80fd\u5355\u72ec\u5c01\u88c5\u3002\u5176\u5047\u8bbe\u95ee\u9898\u89e3\u51b3\u7684\u8fc7\u7a0b\u662f\u4e0d\u53d8\u7684\uff0c\u6240\u4ee5\u5176\u5728\u6570\u636e\u7ed3\u6784\u53d1\u751f\u53d8\u5316\u65f6\u6bcf\u4e2a\u529f\u80fd\u90fd\u9700\u8981\u4fee\u6539\uff0c\u4fee\u6539\u6210\u672c\u9ad8\u3002 \u9762\u5411\u5bf9\u8c61\u5219\u5c06\u6570\u636e\u4e0e\u64cd\u4f5c\u5c01\u88c5\u5728\u4e00\u8d77\uff0c\u901a\u8fc7api\u7684\u65b9\u5f0f\u4e0e\u5916\u754c\u53d1\u751f\u8054\u7cfb\u3002</p>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#_3","title":"\u4e09\u3001\u8fdb\u5236\u4e0e\u7f16\u7801","text":""},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#31","title":"3.1 \u8fdb\u5236\u8f6c\u6362","text":"<ol> <li>R\u8fdb\u5236\u8f6c\u5341\u8fdb\u5236\uff1a\u6570\u503cx\u4f4d\u6743 $(abcd.ef)_R=aR^3+bR^2+cR^1+dR^0$</li> <li>\u5341\u8fdb\u5236\u8f6cR\u8fdb\u5236 \u6574\u6570\u90e8\u5206 \u5c0f\u6570\u90e8\u5206</li> </ol>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#32","title":"3.2 \u7f16\u7801","text":""},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#321","title":"3.2.1 \u539f\u7801","text":"<p>\u8868\u793a\u89c4\u5219\uff1a\u7528\u6700\u9ad8\u4f4d\u8868\u793a\u7b26\u53f7\uff0c\u5176\u4ed6\u4f4d\u5b58\u653e\u8be5\u6570\u4e8c\u8fdb\u5236\u7edd\u5bf9\u503c +3\uff1a0011   -3\uff1a1011 +3-3=0011+1011=1100=-6 \u95ee\u9898\uff1a</p> <ol> <li>0\u6709+0\u548c-0\u4e24\u79cd\u8868\u793a\u5f62\u5f0f\uff0c\u9700\u8981\u5c06-0\u624b\u52a8\u8c03\u6210+0</li> <li>\u52a0\u51cf\u6cd5\u8fd0\u7b97\u8981\u5148\u5224\u65ad\u7b26\u53f7\uff0c\u975e\u5e38\u590d\u6742\uff08\u5426\u5219\u51fa\u73b0+3-3=-6</li> </ol>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#322","title":"3.2.2 \u53cd\u7801","text":"<p>\u8868\u793a\u89c4\u5219\uff1a\u6b63\u6570\u7684\u53cd\u7801\u5c31\u662f\u539f\u7801\uff0c\u8d1f\u6570\u7684\u53cd\u7801\u662f\u7b26\u53f7\u4f4d\u5916\uff0c\u6309\u4f4d\u53d6\u53cd \u89e3\u51b3\u4e86\u5f02\u53f7\u52a0\u6cd5\u7684\u95ee\u9898</p> \u539f\u7801 \u53cd\u7801 +3 0011 0011 -3 1011 1100 <p>\u53cd\u7801\uff1a\uff08+3\uff09+\uff08-3\uff09=1111--&gt;\u539f\u7801:1000=-0 \u95ee\u9898\uff1a</p> <ol> <li>\u4e24\u4e2a\u8d1f\u6570\u76f8\u52a0\u4f1a\u51fa\u73b0\u95ee\u9898\uff08\u6bd4\u771f\u5b9e\u503c\u5c0f1\uff09</li> <li>\u6570\u503c0\u4ecd\u7136\u6709\u4e24\u79cd\u8868\u793a\u65b9\u6cd5</li> </ol>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#323","title":"3.2.3\u8865\u7801","text":"<p>\u8ba1\u7b97\u89c4\u5219\uff1a\u6a21\u6570-\u771f\u5b9e\u503c\uff08\u4e0e\u4e4b\u4e92\u8865\u7684\u4e00\u4e2a\u6570\uff09\uff1a$-k = 2^n-|k|$     \u6a21\u6570\uff1a\u662f\u67d0\u79cd\u8ba1\u91cf\u5668\u7684\u5bb9\u91cf\u3002n\u4f4d\u6574\u6570\uff0c\u5b83\u7684\u6a21\u6570\u5c31\u662f$2^n$ \u601d\u60f3\uff1a \u5f53\u8fdb\u884c\u4e00\u4e2a\u5faa\u73af\u7684\u64cd\u4f5c\u65f6\uff0c\u51cf\u53bb\u4e00\u4e2a\u6570\u4e5f\u53ef\u4ee5\u7b49\u4e8e\u52a0\u4e0a\u4e00\u4e2a\u5b83\u7684\u540c\u4f59\u6570\uff08\u53cd\u6b63\u8d85\u51fa\u7684\u90e8\u5206\u4f1a\u5faa\u73af\uff09\uff0c\u5faa\u73af\u7684\u6700\u5927\u503c\u6210\u4e3a\u6a21\u3002</p> <p>\u5982\u679c\u8bf4\u73b0\u5728\u65f6\u9488\u73b0\u5728\u505c\u572810\u70b9\u949f\uff0c\u90a3\u4e48\u4ec0\u4e48\u65f6\u5019\u4f1a\u505c\u5728\u516b\u70b9\u949f\u5462\uff1f \u7b80\u5355\uff0c\u8fc7\u53bb\u9694\u4e24\u4e2a\u5c0f\u65f6\u7684\u65f6\u5019\u662f\u516b\u70b9\u949f\uff0c\u672a\u6765\u8fc7\u5341\u4e2a\u5c0f\u65f6\u7684\u65f6\u5019\u4e5f\u662f\u516b\u70b9\u949f\u3002 \u4e5f\u5c31\u662f\u8bf4\u65f6\u95f4\u5012\u62e82\u5c0f\u65f6\uff0c\u6216\u6b63\u62e810\u5c0f\u65f6\u90fd\u662f\u516b\u70b9\u949f\u3002 \u4e5f\u5c31\u662f10-2=8\uff0c\u800c\u4e1410+10=8\u3002 \u8fd9\u4e2a\u65f6\u5019\u6ee112\uff0c\u8bf4\u660e\u65f6\u9488\u5728\u8d70\u7b2c\u4e8c\u5708\uff0c\u53c8\u8d70\u4e868\u5c0f\u65f6\uff0c\u6240\u4ee5\u65f6\u9488\u6b63\u597d\u53c8\u505c\u5728\u516b\u70b9\u949f\u3002</p> <p> \u8865\u7801\u7684\u672c\u8d28\uff1a \u8865\u7801\u89e3\u51b3\u7684\u662f\u6df7\u5408\u7f16\u7801\u7684\u95ee\u9898\uff0c\u539f\u7801\u8868\u793a\u8d1f\u6570\u65f6\uff0c\u7b2c\u4e00\u4f4d\u662f\u7801\u5236\uff0c\u5176\u4f59\u662f\u6570\u5236\uff0c\u8fd9\u662f\u4e00\u79cd\u6df7\u5408\u7f16\u7801\uff0c\u65e0\u6cd5\u8fdb\u884c\u6570\u5b66\u8fd0\u7b97\u3002 \u8865\u7801\u7f16\u7801\u5b9e\u8d28\u4e0a\u5c06\u7b2c\u4e00\u4f4d\u7684\u6743\u91cd\u8c03\u6574\uff0c  \u8d1f\u6570\u8865\u7801\u7684\u8ba1\u7b97\uff1a\u6bcf\u4f4d\u53d6\u53cd+1</p>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#_4","title":"\u56db\u3001\u4fe1\u606f\u5b58\u50a8","text":""},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#41","title":"4.1 \u5b58\u50a8\u957f\u5ea6","text":"<p>\u4f4dbit\uff1a\u8868\u793a\u4e00\u4e2a\u4e8c\u8fdb\u5236\u4fe1\u606f\uff080\u62161\uff09 \u5b57\u8282Byte\uff1a\u4e00\u5b57\u8282\u75318\u4f4d\u4e8c\u8fdb\u5236\u6570\u5b57\u7ec4\u6210\uff081Byte=8bit\uff09 1KB=1024B, 1MB=1024KB, 1GB=1024MB \u5b57\u957fWord\uff1a</p>"},{"location":"%E8%AE%A1%E7%AE%97%E6%9C%BA%E8%AF%AD%E8%A8%80%E7%BB%AA%E8%AE%BA/#42","title":"4.2 \u6d6e\u70b9\u6570\u7684\u5b58\u50a8","text":"<p>\u4e09\u7bc7\u975e\u5e38\u597d\u7684\u8bb2\u89e3\uff1a IEEE754\u6807\u51c6: \u4e00 , \u6d6e\u70b9\u6570\u5728\u5185\u5b58\u4e2d\u7684\u5b58\u50a8\u65b9\u5f0f IEEE754\u6807\u51c6: \u4e8c, 32\u4f4d\u6d6e\u70b9\u6570\u7684\u53d6\u503c\u8303\u56f4 IEEE754\u6807\u51c6: \u4e09, \u4e3a\u4ec0\u4e48\u8bf432\u4f4d\u6d6e\u70b9\u6570\u7684\u7cbe\u5ea6\u662f\u201c7\u4f4d\u6709\u6548\u6570\u201d </p>"}]}